#!/bin/bash

# Die Datei, in der Git die aktuelle Commit-Nachricht zwischenspeichert
COMMIT_MSG_FILE=$1

# Der Pfad zu deinem Changelog
CHANGELOG="FULL-CHANGELOG.md"

# 1. Prüfen, ob das Changelog überhaupt existiert
if [ -f "$CHANGELOG" ]; then

    # 2. Suche die erste Versionsnummer im Format vX.Y oder X.Y (nur zwei Zahlen)
    LAST_VERSION=$(grep -oE 'v?[0-9]+\.[0-9]+' "$CHANGELOG" | head -n 1)

    if [ ! -z "$LAST_VERSION" ]; then

        # 3. Das "v" (falls vorhanden) kurz zwischenspeichern und entfernen
        PREFIX=""
        if [[ $LAST_VERSION == v* ]]; then
            PREFIX="v"
            CLEAN_VERSION=${LAST_VERSION#v}
        else
            CLEAN_VERSION=$LAST_VERSION
        fi

        # 4. In Major und Minor aufteilen (getrennt durch den Punkt)
        IFS='.' read -r -a VERSION_PARTS <<< "$CLEAN_VERSION"
        MAJOR="${VERSION_PARTS[0]}"
        MINOR="${VERSION_PARTS[1]}"

        # 5. Die Minor-Version (die zweite Zahl) um 1 erhöhen!
        NEW_MINOR=$((MINOR + 1))
        NEW_VERSION="${PREFIX}${MAJOR}.${NEW_MINOR}"

        # 6. Prüfen, ob das Commit-Feld aktuell leer ist
        if ! grep -qvE '^[[:space:]]*(#|$)' "$COMMIT_MSG_FILE"; then
            # Trage die neue Version als Commit-Nachricht ein
            # (Füge hier gerne direkt deinen Trigger hinzu, z.B. "[RELEASE]")
            echo "Release $NEW_VERSION" > "$COMMIT_MSG_FILE"
        fi
    fi
fi
